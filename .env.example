# Server port (default: 3000)
PORT=3000

# Enable VNC streaming for remote browser interaction (Linux only)
# Requires xvfb, x11vnc, websockify (included in Dockerfile)
VNC_ENABLED=true

# Xvfb display number when VNC_ENABLED=true
XVFB_DISPLAY=99

# Base URL for VNC stream link (e.g. https://your-app.railway.app)
PUBLIC_URL=

# Force headless mode (no visible browser) - use for CI or when no display
# HEADLESS=true
