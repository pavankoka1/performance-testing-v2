# Server port (default: 3000)
PORT=3000

# Force headless mode (no visible browser) - use for CI or when no display
# HEADLESS=true

# (macOS) If you must silence GPU/EGL logs, you can disable GPU (hurts FPS)
# PERFTRACE_DISABLE_GPU=true

# (macOS/Electron) Only if you hit ANGLE/Metal issues, force OpenGL
# PERFTRACE_FORCE_ANGLE_GL=1
